# Vasanthi Creations - Backend Environment Configuration (Production)

# SERVER
NODE_ENV=production
PORT=5000
API_URL=https://api.vasanthicreations.com

# DATABASE
MONGO_URI=mongodb://mongodb:27017/vasanthi_creations

# AUTHENTICATION
JWT_SECRET=replace_with_very_long_random_string
JWT_REFRESH_SECRET=replace_with_another_very_long_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=https://admin.vasanthicreations.com

# PAYMENT GATEWAY (RAZORPAY)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# EMAIL (SMTP/SENDGRID/AWS SES)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=Vasanthi Creations <noreply@vasanthicreations.com>

# UPLOADS
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
