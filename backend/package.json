    "start": "node dist/server.js",
    "start:prod": "cross-env NODE_ENV=production node dist/server.js",
    "seed": "ts-node src/database/seeds/index.ts",
    "test:realtime": "ts-node --transpile-only src/realtime/__tests__/realtime.integration.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "saree",
    "ethnic",
    "fashion",
    "boutique",
    "api"
  ],
  "author": "Vasanthi Creations",
  "license": "UNLICENSED",
  "private": true,
