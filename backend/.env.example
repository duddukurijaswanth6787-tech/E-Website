NODE_ENV=development
PORT=5000
# Local dev; in production set to your deployed SPA origin (must match browser URL for CORS)
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/vasanthi_creations

# Redis
# Set to empty to disable Redis (OTP/caching will fall back in dev)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP) — use SMTP_* OR EMAIL_* (both work)
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password
MAIL_FROM="Vasanthi Creations <noreply@vasanthicreations.com>"

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# AWS S3 (to be configured after Phase 2)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=vasanthi-creations-media

# Cloudinary (alternative to S3 - to be configured after Phase 2)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# Admin Seed (initial super admin)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@vasanthicreations.com
SEED_ADMIN_PASSWORD=Admin@12345!
