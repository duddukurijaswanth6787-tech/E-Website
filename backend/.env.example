# ==============================================================================
# VASANTHI CREATIONS - BACKEND ENVIRONMENT TEMPLATE
# ==============================================================================
# Instructions:
# 1. Copy this file to .env (cp .env.example .env)
# 2. Fill in the values for your local environment
# 3. DO NOT commit your local .env to version control
# ==============================================================================

# Core Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database & Cache (Railway will provide these in production)
MONGO_URI=mongodb://localhost:27017/vasanthi_creations
REDIS_URL=redis://localhost:6379
# LOCAL_REDIS_URL=redis://192.168.1.13:6379 # Optional: LAN development access

# Security (Use high-entropy strings)
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email Infrastructure (SMTP)
MAIL_ENABLED=true
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
MAIL_FROM=noreply@whcservice.in

# Cloud Storage (AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-production-bucket-name

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Seed Data (Initial Admin)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=Admin@123
