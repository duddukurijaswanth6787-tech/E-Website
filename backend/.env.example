# Vasanthi Creations ERP - PRODUCTION SECRETS (TEMPLATE)
# DO NOT COMMIT THIS FILE TO GIT. RENAME TO .env.production AND FILL IN SECRETS.

NODE_ENV=production
PORT=5000
FRONTEND_URL=https://whcservice.in

# 1. MongoDB Atlas (CRITICAL: Change your password in Atlas Dashboard)
MONGO_URI=mongodb+srv://[NEW_USER]:[NEW_STRONG_PASSWORD]@[YOUR_CLUSTER].mongodb.net/ecommerce?retryWrites=true&w=majority

# 2. Redis (CRITICAL: Rotate your Upstash password)
REDIS_URL=redis://default:[NEW_UPSTASH_PASSWORD]@your-redis-url.upstash.io:port

# 3. JWT Security (REGENERATED: Rotate these values immediately)
# Use 'openssl rand -base64 48' to generate new secrets
JWT_ACCESS_SECRET=[REPLACE_WITH_NEW_48_CHAR_SECRET]
JWT_REFRESH_SECRET=[REPLACE_WITH_NEW_48_CHAR_SECRET]
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 4. SMTP / Transactional Email (REGENERATED: Revoke old App Password)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=[REPLACE_WITH_NEW_RESEND_API_KEY]
MAIL_FROM="Vasanthi Creations <noreply@whcservice.in>"

# 5. Razorpay (REGENERATED: Deactivate old keys in Dashboard)
RAZORPAY_KEY_ID=rzp_live_[NEW_KEY_ID]
RAZORPAY_KEY_SECRET=[NEW_KEY_SECRET]
RAZORPAY_WEBHOOK_SECRET=[NEW_LONG_WEBHOOK_SECRET]

# 6. AWS S3 (REGENERATED: Delete old IAM keys immediately)
AWS_ACCESS_KEY_ID=[NEW_IAM_ACCESS_KEY]
AWS_SECRET_ACCESS_KEY=[NEW_IAM_SECRET_KEY]
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=vs-boutique-images

# 7. Security Hardening
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
MAX_FILE_SIZE_MB=10
LOG_LEVEL=info
